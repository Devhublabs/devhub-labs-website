# Copy to `.env` (or set in your Vercel project) and fill in.
# All VITE_* values are embedded in the client bundle, so only use
# keys that are safe to expose publicly.

# Web3Forms access key for the contact form.
# Create one (free) at https://web3forms.com — it is a public key, not a secret.
VITE_WEB3FORMS_KEY=

# Full production site root (no trailing slash). Used for canonical URLs,
# Open Graph tags, and asset URLs. Defaults to the Vercel project URL.
# Set this if you attach a custom domain, e.g. https://devhublabs.com
VITE_SITE_URL=https://devhub-labs-website.vercel.app
